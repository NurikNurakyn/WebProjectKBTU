      },
      "response": [{ "name": "200 Mountain Detail", "status": "OK", "code": 200, "body": "{\n  \"id\": 1,\n  \"name\": \"Talgar Peak\",\n  \"location\": \"Trans-Ili Alatau\"\n}" }]
    },
    {
      "name": "Mountains - Update",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Talgar Peak Updated\",\n  \"location\": \"Trans-Ili Alatau\",\n  \"image_url\": \"https://example.com/updated.jpg\",\n  \"elevation_m\": 4979,\n  \"difficulty\": \"Advanced\",\n  \"description\": \"Updated description\",\n  \"is_featured\": true\n}" },
        "url": { "raw": "{{baseUrl}}/mountains/{{mountainId}}/", "host": ["{{baseUrl}}"], "path": ["mountains", "{{mountainId}}", ""] }
      },
      "response": [{ "name": "200 Mountain Updated", "status": "OK", "code": 200, "body": "{\n  \"id\": 1,\n  \"name\": \"Talgar Peak Updated\"\n}" }]
    },
    {
      "name": "Mountains - Delete",
      "request": {
        "method": "DELETE",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/mountains/{{mountainId}}/", "host": ["{{baseUrl}}"], "path": ["mountains", "{{mountainId}}", ""] }
      },
      "response": [{ "name": "204 Mountain Deleted", "status": "No Content", "code": 204, "body": "" }]
    },
    {
      "name": "Ascents - List",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/ascents/", "host": ["{{baseUrl}}"], "path": ["ascents", ""] }
      },
      "response": [{ "name": "200 Ascents", "status": "OK", "code": 200, "body": "[]" }]
    },
    {
