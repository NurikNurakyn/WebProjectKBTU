  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"climber01\",\n  \"email\": \"climber01@example.com\",\n  \"password\": \"StrongPass123\",\n  \"full_name\": \"Alex Climber\",\n  \"country\": \"Kazakhstan\"\n}" },
        "url": { "raw": "{{baseUrl}}/register/", "host": ["{{baseUrl}}"], "path": ["register", ""] }
      },
      "response": [{ "name": "201 Register", "status": "Created", "code": 201, "body": "{\n  \"id\": 1,\n  \"username\": \"climber01\",\n  \"email\": \"climber01@example.com\"\n}" }]
    },
    {
      "name": "Auth - Login (JWT)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"climber01\",\n  \"password\": \"StrongPass123\"\n}" },
        "url": { "raw": "{{baseUrl}}/login/", "host": ["{{baseUrl}}"], "path": ["login", ""] }
      },
      "response": [{ "name": "200 Login", "status": "OK", "code": 200, "body": "{\n  \"access\": \"<jwt_access_token>\",\n  \"refresh\": \"<jwt_refresh_token>\",\n  \"user\": {\n    \"id\": 1,\n    \"username\": \"climber01\",\n    \"email\": \"climber01@example.com\"\n  }\n}" }]
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}" },
        "url": { "raw": "{{baseUrl}}/logout/", "host": ["{{baseUrl}}"], "path": ["logout", ""] }
      },
      "response": [{ "name": "200 Logout", "status": "OK", "code": 200, "body": "{\n  \"message\": \"Logged out successfully.\"\n}" }]
    },
    {
      "name": "Profile - Get",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
        "url": { "raw": "{{baseUrl}}/profile/", "host": ["{{baseUrl}}"], "path": ["profile", ""] }
      },
      "response": [{ "name": "200 Profile", "status": "OK", "code": 200, "body": "{\n  \"username\": \"climber01\",\n  \"email\": \"climber01@example.com\",\n  \"country\": \"Kazakhstan\",\n  \"bio\": \"\",\n  \"experience_points\": 0,\n  \"level\": 1,\n  \"rank_title\": \"Novice\",\n  \"next_rank\": {\n    \"title\": \"Tourist\",\n    \"threshold\": 500,\n    \"points_left\": 500\n  },\n  \"ascents_count\": 0\n}" }]
    },
