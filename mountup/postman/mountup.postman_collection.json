      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"mountain\": {{mountainId}},\n  \"climbed_on\": \"2026-04-10\",\n  \"notes\": \"Windy but manageable\",\n  \"status\": \"confirmed\"\n}" },
        "url": { "raw": "{{baseUrl}}/ascents/", "host": ["{{baseUrl}}"], "path": ["ascents", ""] }
      },
      "response": [{ "name": "201 Ascent Created", "status": "Created", "code": 201, "body": "{\n  \"id\": 1,\n  \"status\": \"confirmed\"\n}" }]
    },
    {
      "name": "Comments - List",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/comments/?mountain={{mountainId}}", "host": ["{{baseUrl}}"], "path": ["comments", ""], "query": [{ "key": "mountain", "value": "{{mountainId}}" }] }
      },
      "response": [{ "name": "200 Comments", "status": "OK", "code": 200, "body": "[]" }]
    },
    {
      "name": "Comments - Create",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"mountain\": {{mountainId}},\n  \"body\": \"Great route for spring training!\"\n}" },
        "url": { "raw": "{{baseUrl}}/comments/", "host": ["{{baseUrl}}"], "path": ["comments", ""] }
      },
      "response": [{ "name": "201 Comment Created", "status": "Created", "code": 201, "body": "{\n  \"id\": 1,\n  \"body\": \"Great route for spring training!\"\n}" }]
