        ],
        "body": { "mode": "raw", "raw": "{\n  \"name\": \"Talgar Peak\",\n  \"location\": \"Trans-Ili Alatau\",\n  \"image_url\": \"https://example.com/photo.jpg\",\n  \"elevation_m\": 4979,\n  \"difficulty\": \"Advanced\",\n  \"description\": \"High-altitude challenge\",\n  \"is_featured\": false\n}" },
        "url": { "raw": "{{baseUrl}}/mountains/", "host": ["{{baseUrl}}"], "path": ["mountains", ""] }
